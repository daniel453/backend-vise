APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cuentas SMTP adicionales para repartir el envío del boletín (evita los límites
# diarios de Gmail) y para failover. Se activan poniendo MAIL2_*/MAIL3_*.
MAIL2_HOST=smtp.gmail.com
MAIL2_PORT=587
MAIL2_USERNAME=
MAIL2_PASSWORD=
MAIL3_HOST=smtp.gmail.com
MAIL3_PORT=587
MAIL3_USERNAME=
MAIL3_PASSWORD=

# Envío del boletín nacional:
# - Token compartido que manda n8n (header X-Dispatch-Token).
BULLETIN_DISPATCH_TOKEN=
# - Mailer: 'smtp' (una cuenta) o 'roundrobin' (varias, con balanceo + failover).
BULLETIN_DISPATCH_MAILER=smtp
# - Cuentas que usa 'roundrobin' (coma-separadas).
BULLETIN_DISPATCH_MAILERS=smtp,smtp2,smtp3
# - Hora de INICIO (Colombia). No se envía antes. Días normales: 1 vez/día desde
#   esta hora. Fechas especiales: cada 2h desde esta hora (nada de madrugada).
BULLETIN_DISPATCH_DAILY_HOUR=8

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
